{
  "datasets": [
    {
      "name": "top20_engajamento",
      "displayName": "Top 20 Deputados por Engajamento",
      "queryLines": [
        "SELECT\n",
        "  nome,\n",
        "  sigla_partido,\n",
        "  sigla_uf,\n",
        "  score_engajamento,\n",
        "  qtde_votacoes,\n",
        "  qtde_frentes\n",
        "FROM\n",
        "  workspace.default.gold_camara_engajamento_deputados\n",
        "ORDER BY\n",
        "  score_engajamento DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "engajamento_partido",
      "displayName": "Engajamento por Partido",
      "queryLines": [
        "SELECT\n",
        "  sigla_partido,\n",
        "  AVG(score_engajamento) as score_medio,\n",
        "  COUNT(*) as qtde_deputados\n",
        "FROM\n",
        "  workspace.default.gold_camara_engajamento_deputados\n",
        "WHERE\n",
        "  sigla_partido IS NOT NULL\n",
        "GROUP BY\n",
        "  sigla_partido\n",
        "ORDER BY\n",
        "  score_medio DESC\n",
        "LIMIT 15"
      ]
    },
    {
      "name": "engajamento_geral",
      "displayName": "Dados Gerais de Engajamento",
      "queryLines": [
        "SELECT\n",
        "  *\n",
        "FROM\n",
        "  workspace.default.gold_camara_engajamento_deputados"
      ]
    },
    {
      "name": "eventos_temporal",
      "displayName": "Eventos por Mês",
      "queryLines": [
        "SELECT\n",
        "  MAKE_DATE(ano, mes, 1) as data_mes,\n",
        "  CAST(qtde_eventos AS INT) as qtde_eventos,\n",
        "  CAST(qtde_tipos_eventos AS INT) as qtde_tipos_eventos\n",
        "FROM\n",
        "  workspace.default.gold_camara_eventos_por_mes\n",
        "ORDER BY\n",
        "  ano,\n",
        "  mes"
      ]
    },
    {
      "name": "eventos_ano",
      "displayName": "Eventos por Ano",
      "queryLines": [
        "SELECT\n",
        "  ano,\n",
        "  SUM(qtde_eventos) as total_eventos,\n",
        "  SUM(qtde_tipos_eventos) as total_tipos\n",
        "FROM\n",
        "  workspace.default.gold_camara_eventos_por_mes\n",
        "GROUP BY\n",
        "  ano\n",
        "ORDER BY\n",
        "  ano"
      ]
    },
    {
      "name": "anomalias_top",
      "displayName": "Top Anomalias em Despesas",
      "queryLines": [
        "SELECT\n",
        "  nome,\n",
        "  sigla_partido,\n",
        "  sigla_uf,\n",
        "  tipoDespesa,\n",
        "  valor_liquido,\n",
        "  media,\n",
        "  z_score,\n",
        "  data_documento\n",
        "FROM\n",
        "  workspace.default.gold_camara_anomalias_despesas\n",
        "WHERE\n",
        "  z_score IS NOT NULL\n",
        "ORDER BY\n",
        "  z_score DESC\n",
        "LIMIT 100"
      ]
    },
    {
      "name": "anomalias_stats",
      "displayName": "Estatísticas de Anomalias",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) as total_anomalias,\n",
        "  AVG(z_score) as z_score_medio,\n",
        "  AVG(valor_liquido) as valor_medio\n",
        "FROM\n",
        "  workspace.default.gold_camara_anomalias_despesas\n",
        "WHERE\n",
        "  z_score IS NOT NULL\n",
        "  AND z_score > 2"
      ]
    },
    {
      "name": "anomalias_por_tipo",
      "displayName": "Anomalias por Tipo de Despesa",
      "queryLines": [
        "SELECT\n",
        "  tipoDespesa,\n",
        "  COUNT(*) as qtde_anomalias,\n",
        "  AVG(z_score) as z_score_medio,\n",
        "  AVG(valor_liquido) as valor_medio\n",
        "FROM\n",
        "  workspace.default.gold_camara_anomalias_despesas\n",
        "WHERE\n",
        "  z_score IS NOT NULL\n",
        "  AND z_score > 2\n",
        "GROUP BY\n",
        "  tipoDespesa\n",
        "ORDER BY\n",
        "  qtde_anomalias DESC\n",
        "LIMIT 15"
      ]
    },
    {
      "name": "eventos_por_ano",
      "displayName": "Eventos por Ano",
      "queryLines": [
        "SELECT\n",
        "  CAST(ano AS INT) as ano,\n",
        "  CAST(SUM(qtde_eventos) AS INT) as total_eventos\n",
        "FROM\n",
        "  workspace.default.gold_camara_eventos_por_mes\n",
        "GROUP BY\n",
        "  ano\n",
        "ORDER BY\n",
        "  ano"
      ]
    },
    {
      "name": "eventos_metricas",
      "displayName": "Métricas de Eventos",
      "queryLines": [
        "SELECT\n",
        "  SUM(qtde_eventos) as total_eventos,\n",
        "  AVG(qtde_eventos) as media_mensal\n",
        "FROM\n",
        "  workspace.default.gold_camara_eventos_por_mes"
      ]
    },
    {
      "name": "deputados_anomalias",
      "displayName": "Top 20 Deputados com Mais Anomalias",
      "queryLines": [
        "SELECT\n",
        "  nome,\n",
        "  COUNT(*) as qtde_anomalias,\n",
        "  AVG(z_score) as z_score_medio,\n",
        "  AVG(valor_liquido) as valor_medio\n",
        "FROM\n",
        "  workspace.default.gold_camara_anomalias_despesas\n",
        "WHERE\n",
        "  z_score IS NOT NULL\n",
        "GROUP BY\n",
        "  nome\n",
        "ORDER BY\n",
        "  qtde_anomalias DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "anomalias_por_partido",
      "displayName": "Anomalias por Partido",
      "queryLines": [
        "SELECT\n",
        "  sigla_partido,\n",
        "  COUNT(*) as qtde_anomalias,\n",
        "  AVG(z_score) as z_score_medio,\n",
        "  AVG(valor_liquido) as valor_medio\n",
        "FROM\n",
        "  workspace.default.gold_camara_anomalias_despesas\n",
        "WHERE\n",
        "  z_score IS NOT NULL\n",
        "  AND sigla_partido IS NOT NULL\n",
        "GROUP BY\n",
        "  sigla_partido\n",
        "ORDER BY\n",
        "  qtde_anomalias DESC\n",
        "LIMIT 15"
      ]
    }
  ],
