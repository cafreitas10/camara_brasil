{
  "datasets": [
    {
      "name": "fornecedores_scatter",
      "displayName": "Fornecedores - Dados Individuais",
      "queryLines": [
        "SELECT\n",
        "  nomeFornecedor,\n",
        "  total_recebido,\n",
        "  qtde_deputados_atendidos,\n",
        "  qtde_transacoes\n",
        "FROM\n",
        "  workspace.default.gold_camara_ranking_fornecedores"
      ]
    },
    {
      "name": "top15_transacoes",
      "displayName": "Top 15 Fornecedores por Transações",
      "queryLines": [
        "SELECT\n",
        "  nomeFornecedor,\n",
        "  qtde_transacoes\n",
        "FROM\n",
        "  workspace.default.gold_camara_ranking_fornecedores\n",
        "ORDER BY\n",
        "  qtde_transacoes DESC\n",
        "LIMIT 15"
      ]
    },
    {
      "name": "top20_valor",
      "displayName": "Top 20 Fornecedores por Valor",
      "queryLines": [
        "SELECT\n",
        "  nomeFornecedor,\n",
        "  total_recebido\n",
        "FROM\n",
        "  workspace.default.gold_camara_ranking_fornecedores\n",
        "ORDER BY\n",
        "  total_recebido DESC\n",
        "LIMIT 20"
      ]
    }
  ],
  "pages": [
    {
      "name": "5800b999",
      "displayName": "Page 1",
      "layout": [
