{
  "datasets": [
    {
      "name": "eventos_recentes",
      "displayName": "Eventos Recentes",
      "queryLines": [
        "SELECT\n",
        "  dataHoraInicio,\n",
        "  descricaoTipo,\n",
        "  localCamara\n",
        "FROM\n",
        "  workspace.default.silver_camara_fact_eventos\n",
        "WHERE\n",
        "  dataHoraInicio IS NOT NULL\n",
        "ORDER BY\n",
        "  dataHoraInicio DESC\n",
        "LIMIT 20"
      ]
    },
    {
      "name": "top_tipos_eventos",
      "displayName": "Top 10 Tipos de Eventos",
      "queryLines": [
        "SELECT\n",
        "  descricaoTipo,\n",
        "  COUNT(*) as quantidade\n",
        "FROM\n",
        "  workspace.default.silver_camara_fact_eventos\n",
        "WHERE\n",
        "  descricaoTipo IS NOT NULL\n",
        "GROUP BY\n",
        "  descricaoTipo\n",
        "ORDER BY\n",
        "  quantidade DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "total_eventos",
      "displayName": "Total de Eventos",
      "queryLines": [
        "SELECT\n",
        "  COUNT(*) as total\n",
        "FROM\n",
        "  workspace.default.silver_camara_fact_eventos"
      ]
    },
    {
      "name": "eventos_ao_longo_tempo",
      "displayName": "Eventos ao Longo do Tempo",
      "queryLines": [
        "SELECT\n",
        "  ano,\n",
        "  mes,\n",
        "  COUNT(*) as total_eventos\n",
        "FROM\n",
        "  workspace.default.silver_camara_fact_eventos\n",
        "GROUP BY\n",
        "  ano,\n",
        "  mes\n",
        "ORDER BY\n",
        "  ano,\n",
        "  mes"
      ]
    },
    {
      "name": "distribuicao_tipo",
      "displayName": "Distribuição por Tipo",
      "queryLines": [
        "SELECT\n",
        "  tipoDespesa,\n",
        "  total_gasto\n",
        "FROM\n",
        "  workspace.default.gold_camara_despesas_por_tipo\n",
        "ORDER BY\n",
        "  total_gasto DESC\n",
        "LIMIT 10"
      ]
    },
    {
      "name": "detalhes_categoria",
      "displayName": "Detalhes por Categoria",
      "queryLines": [
        "SELECT\n",
        "  tipoDespesa,\n",
        "  total_gasto,\n",
        "  media_gasto,\n",
        "  qtde_transacoes,\n",
        "  qtde_deputados\n",
        "FROM\n",
        "  workspace.default.gold_camara_despesas_por_tipo\n",
        "ORDER BY\n",
        "  total_gasto DESC"
      ]
    },
    {
      "name": "total_gasto",
      "displayName": "Total Gasto",
      "queryLines": [
        "SELECT\n",
        "  SUM(total_gasto) as total\n",
        "FROM\n",
        "  workspace.default.gold_camara_despesas_por_tipo"
      ]
    }
  ],
